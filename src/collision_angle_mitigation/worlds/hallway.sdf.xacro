<?xml version="1.0"?>
<sdf version="1.6" xmlns:xacro="http://www.ros.org/wiki/xacro">
  <xacro:arg name="headless" default="true"/>

  <!--
    Hallway world matching hallway.pgm / hallway.yaml dimensions.

    Map  : 768 x 384 px @ 0.05 m/px  →  38.4 m (X) × 19.2 m (Y)
    Origin: [-19.2, -9.6, 0]

    Free space (hallway): Y ∈ [-4.8, 4.8]  (9.6 m wide, half the original map width)
    Top wall             : Y ∈ [ 4.8,  9.6] (4.8 m thick)  →  centre y =  7.2
    Bottom wall          : Y ∈ [-9.6, -4.8] (4.8 m thick)  →  centre y = -7.2
    Wall length          : 38.4 m along X                   →  centre x =  0.0
  -->

  <world name="default">
    <plugin
      filename="gz-sim-physics-system"
      name="gz::sim::systems::Physics">
    </plugin>
    <plugin
      filename="gz-sim-user-commands-system"
      name="gz::sim::systems::UserCommands">
    </plugin>
    <xacro:unless value="$(arg headless)">
      <plugin
        filename="gz-sim-scene-broadcaster-system"
        name="gz::sim::systems::SceneBroadcaster">
      </plugin>
    </xacro:unless>
    <plugin
      filename="gz-sim-sensors-system"
      name="gz::sim::systems::Sensors">
      <render_engine>ogre2</render_engine>
    </plugin>
    <plugin
      filename="gz-sim-imu-system"
      name="gz::sim::systems::Imu">
    </plugin>

    <light name='sun' type='directional'>
      <cast_shadows>0</cast_shadows>
      <pose>0 0 10 0 0 0</pose>
      <diffuse>0.8 0.8 0.8 1</diffuse>
      <specular>0.8 0.8 0.8 1</specular>
      <attenuation>
        <range>1000</range>
        <constant>0.9</constant>
        <linear>0.01</linear>
        <quadratic>0.001</quadratic>
      </attenuation>
      <direction>-0.5 0.1 -0.9</direction>
    </light>

    <model name='ground_plane'>
      <static>1</static>
      <link name='link'>
        <collision name='collision'>
          <geometry>
            <plane>
              <normal>0 0 1</normal>
              <size>100 100</size>
            </plane>
          </geometry>
          <max_contacts>10</max_contacts>
        </collision>
        <visual name='visual'>
          <geometry>
            <plane>
              <normal>0 0 1</normal>
              <size>100 100</size>
            </plane>
          </geometry>
          <material>
            <ambient>0.8 0.8 0.8 1</ambient>
            <diffuse>0.8 0.8 0.8 1</diffuse>
            <specular>0.8 0.8 0.8 1</specular>
          </material>
        </visual>
      </link>
    </model>

    <scene>
      <shadows>0</shadows>
    </scene>

    <physics name='3ms' type='ode'>
      <max_step_size>0.003</max_step_size>
      <real_time_factor>1</real_time_factor>
    </physics>

    <!-- Top wall: Y ∈ [+1.30, +9.60], centre at y=+5.45, 38.4 m long, 8.30 m thick, 1 m tall -->
    <model name="hallway_wall_top">
      <static>1</static>
      <pose>0 5.45 0.5 0 0 0</pose>
      <link name="link">
        <collision name="collision">
          <geometry>
            <box><size>38.4 8.3 1.0</size></box>
          </geometry>
        </collision>
        <visual name="visual">
          <geometry>
            <box><size>38.4 8.3 1.0</size></box>
          </geometry>
          <material>
            <ambient>0.4 0.4 0.4 1</ambient>
            <diffuse>0.5 0.5 0.5 1</diffuse>
            <specular>0.1 0.1 0.1 1</specular>
          </material>
        </visual>
      </link>
    </model>

    <!-- Bottom wall: Y ∈ [-9.60, -1.30], centre at y=-5.45, 38.4 m long, 8.30 m thick, 1 m tall -->
    <model name="hallway_wall_bottom">
      <static>1</static>
      <pose>0 -5.45 0.5 0 0 0</pose>
      <link name="link">
        <collision name="collision">
          <geometry>
            <box><size>38.4 8.3 1.0</size></box>
          </geometry>
        </collision>
        <visual name="visual">
          <geometry>
            <box><size>38.4 8.3 1.0</size></box>
          </geometry>
          <material>
            <ambient>0.4 0.4 0.4 1</ambient>
            <diffuse>0.5 0.5 0.5 1</diffuse>
            <specular>0.1 0.1 0.5 1</specular>
          </material>
        </visual>
      </link>
    </model>

    <!-- Left end cap: closes the hallway at x = -19.2 -->
    <model name="hallway_cap_left">
      <static>1</static>
      <pose>-19.7 0 0.5 0 0 0</pose>
      <link name="link">
        <collision name="collision">
          <geometry>
            <box><size>1.0 2.6 1.0</size></box>
          </geometry>
        </collision>
        <visual name="visual">
          <geometry>
            <box><size>1.0 2.6 1.0</size></box>
          </geometry>
          <material>
            <ambient>0.4 0.4 0.4 1</ambient>
            <diffuse>0.5 0.5 0.5 1</diffuse>
            <specular>0.1 0.1 0.1 1</specular>
          </material>
        </visual>
      </link>
    </model>

    <!-- Right end cap: closes the hallway at x = +19.2 -->
    <model name="hallway_cap_right">
      <static>1</static>
      <pose>19.7 0 0.5 0 0 0</pose>
      <link name="link">
        <collision name="collision">
          <geometry>
            <box><size>1.0 2.6 1.0</size></box>
          </geometry>
        </collision>
        <visual name="visual">
          <geometry>
            <box><size>1.0 2.6 1.0</size></box>
          </geometry>
          <material>
            <ambient>0.4 0.4 0.4 1</ambient>
            <diffuse>0.5 0.5 0.5 1</diffuse>
            <specular>0.1 0.1 0.1 1</specular>
          </material>
        </visual>
      </link>
    </model>

    <!-- =====================================================================
         Localization landmarks: 19 protrusions every 2 m from x=-18 to x=+18.
         Strict alternating top/bottom.  Five size classes (S W M D L) cycling
         across all positions — each produces a unique 2-D laser scan signature.
         S: 0.25×0.15  W: 1.20×0.20  M: 0.50×0.30  D: 0.35×0.40  L: 0.90×0.35
         Top inner face y=+1.30, bottom inner face y=-1.30.
         Protrusion box centre y = ±(1.30 - depth/2).
    ===================================================================== -->

    <!-- x=-18 : top wall  [S: 0.25m wide × 0.15m deep] -->
    <model name="landmark_top_neg18">
      <static>1</static>
      <pose>-18 1.2250 0.5 0 0 0</pose>
      <link name="link">
        <collision name="collision">
          <geometry><box><size>0.25 0.15 1.0</size></box></geometry>
        </collision>
        <visual name="visual">
          <geometry><box><size>0.25 0.15 1.0</size></box></geometry>
          <material>
            <ambient>0.3 0.3 0.5 1</ambient>
            <diffuse>0.4 0.4 0.6 1</diffuse>
            <specular>0.1 0.1 0.1 1</specular>
          </material>
        </visual>
      </link>
    </model>

    <!-- x=-16 : bottom wall  [W: 1.20m wide × 0.20m deep] -->
    <model name="landmark_bot_neg16">
      <static>1</static>
      <pose>-16 -1.2000 0.5 0 0 0</pose>
      <link name="link">
        <collision name="collision">
          <geometry><box><size>1.20 0.20 1.0</size></box></geometry>
        </collision>
        <visual name="visual">
          <geometry><box><size>1.20 0.20 1.0</size></box></geometry>
          <material>
            <ambient>0.3 0.3 0.5 1</ambient>
            <diffuse>0.4 0.4 0.6 1</diffuse>
            <specular>0.1 0.1 0.1 1</specular>
          </material>
        </visual>
      </link>
    </model>

    <!-- x=-14 : top wall  [M: 0.50m wide × 0.30m deep] -->
    <model name="landmark_top_neg14">
      <static>1</static>
      <pose>-14 1.1500 0.5 0 0 0</pose>
      <link name="link">
        <collision name="collision">
          <geometry><box><size>0.50 0.30 1.0</size></box></geometry>
        </collision>
        <visual name="visual">
          <geometry><box><size>0.50 0.30 1.0</size></box></geometry>
          <material>
            <ambient>0.3 0.3 0.5 1</ambient>
            <diffuse>0.4 0.4 0.6 1</diffuse>
            <specular>0.1 0.1 0.1 1</specular>
          </material>
        </visual>
      </link>
    </model>

    <!-- x=-12 : bottom wall  [D: 0.35m wide × 0.40m deep] -->
    <model name="landmark_bot_neg12">
      <static>1</static>
      <pose>-12 -1.1000 0.5 0 0 0</pose>
      <link name="link">
        <collision name="collision">
          <geometry><box><size>0.35 0.40 1.0</size></box></geometry>
        </collision>
        <visual name="visual">
          <geometry><box><size>0.35 0.40 1.0</size></box></geometry>
          <material>
            <ambient>0.3 0.3 0.5 1</ambient>
            <diffuse>0.4 0.4 0.6 1</diffuse>
            <specular>0.1 0.1 0.1 1</specular>
          </material>
        </visual>
      </link>
    </model>

    <!-- x=-10 : top wall  [L: 0.90m wide × 0.35m deep] -->
    <model name="landmark_top_neg10">
      <static>1</static>
      <pose>-10 1.1250 0.5 0 0 0</pose>
      <link name="link">
        <collision name="collision">
          <geometry><box><size>0.90 0.35 1.0</size></box></geometry>
        </collision>
        <visual name="visual">
          <geometry><box><size>0.90 0.35 1.0</size></box></geometry>
          <material>
            <ambient>0.3 0.3 0.5 1</ambient>
            <diffuse>0.4 0.4 0.6 1</diffuse>
            <specular>0.1 0.1 0.1 1</specular>
          </material>
        </visual>
      </link>
    </model>

    <!-- x=-8 : bottom wall  [S: 0.25m wide × 0.15m deep] -->
    <model name="landmark_bot_neg8">
      <static>1</static>
      <pose>-8 -1.2250 0.5 0 0 0</pose>
      <link name="link">
        <collision name="collision">
          <geometry><box><size>0.25 0.15 1.0</size></box></geometry>
        </collision>
        <visual name="visual">
          <geometry><box><size>0.25 0.15 1.0</size></box></geometry>
          <material>
            <ambient>0.3 0.3 0.5 1</ambient>
            <diffuse>0.4 0.4 0.6 1</diffuse>
            <specular>0.1 0.1 0.1 1</specular>
          </material>
        </visual>
      </link>
    </model>

    <!-- x=-6 : top wall  [W: 1.20m wide × 0.20m deep] -->
    <model name="landmark_top_neg6">
      <static>1</static>
      <pose>-6 1.2000 0.5 0 0 0</pose>
      <link name="link">
        <collision name="collision">
          <geometry><box><size>1.20 0.20 1.0</size></box></geometry>
        </collision>
        <visual name="visual">
          <geometry><box><size>1.20 0.20 1.0</size></box></geometry>
          <material>
            <ambient>0.3 0.3 0.5 1</ambient>
            <diffuse>0.4 0.4 0.6 1</diffuse>
            <specular>0.1 0.1 0.1 1</specular>
          </material>
        </visual>
      </link>
    </model>

    <!-- x=-4 : bottom wall  [M: 0.50m wide × 0.30m deep] -->
    <model name="landmark_bot_neg4">
      <static>1</static>
      <pose>-4 -1.1500 0.5 0 0 0</pose>
      <link name="link">
        <collision name="collision">
          <geometry><box><size>0.50 0.30 1.0</size></box></geometry>
        </collision>
        <visual name="visual">
          <geometry><box><size>0.50 0.30 1.0</size></box></geometry>
          <material>
            <ambient>0.3 0.3 0.5 1</ambient>
            <diffuse>0.4 0.4 0.6 1</diffuse>
            <specular>0.1 0.1 0.1 1</specular>
          </material>
        </visual>
      </link>
    </model>

    <!-- x=-2 : top wall  [D: 0.35m wide × 0.40m deep] -->
    <model name="landmark_top_neg2">
      <static>1</static>
      <pose>-2 1.1000 0.5 0 0 0</pose>
      <link name="link">
        <collision name="collision">
          <geometry><box><size>0.35 0.40 1.0</size></box></geometry>
        </collision>
        <visual name="visual">
          <geometry><box><size>0.35 0.40 1.0</size></box></geometry>
          <material>
            <ambient>0.3 0.3 0.5 1</ambient>
            <diffuse>0.4 0.4 0.6 1</diffuse>
            <specular>0.1 0.1 0.1 1</specular>
          </material>
        </visual>
      </link>
    </model>

    <!-- x=0 : bottom wall  [L: 0.90m wide × 0.35m deep] -->
    <model name="landmark_bot_0">
      <static>1</static>
      <pose>0 -1.1250 0.5 0 0 0</pose>
      <link name="link">
        <collision name="collision">
          <geometry><box><size>0.90 0.35 1.0</size></box></geometry>
        </collision>
        <visual name="visual">
          <geometry><box><size>0.90 0.35 1.0</size></box></geometry>
          <material>
            <ambient>0.3 0.3 0.5 1</ambient>
            <diffuse>0.4 0.4 0.6 1</diffuse>
            <specular>0.1 0.1 0.1 1</specular>
          </material>
        </visual>
      </link>
    </model>

    <!-- x=+2 : top wall  [S: 0.25m wide × 0.15m deep] -->
    <model name="landmark_top_pos2">
      <static>1</static>
      <pose>2 1.2250 0.5 0 0 0</pose>
      <link name="link">
        <collision name="collision">
          <geometry><box><size>0.25 0.15 1.0</size></box></geometry>
        </collision>
        <visual name="visual">
          <geometry><box><size>0.25 0.15 1.0</size></box></geometry>
          <material>
            <ambient>0.3 0.3 0.5 1</ambient>
            <diffuse>0.4 0.4 0.6 1</diffuse>
            <specular>0.1 0.1 0.1 1</specular>
          </material>
        </visual>
      </link>
    </model>

    <!-- x=+4 : bottom wall  [W: 1.20m wide × 0.20m deep] -->
    <model name="landmark_bot_pos4">
      <static>1</static>
      <pose>4 -1.2000 0.5 0 0 0</pose>
      <link name="link">
        <collision name="collision">
          <geometry><box><size>1.20 0.20 1.0</size></box></geometry>
        </collision>
        <visual name="visual">
          <geometry><box><size>1.20 0.20 1.0</size></box></geometry>
          <material>
            <ambient>0.3 0.3 0.5 1</ambient>
            <diffuse>0.4 0.4 0.6 1</diffuse>
            <specular>0.1 0.1 0.1 1</specular>
          </material>
        </visual>
      </link>
    </model>

    <!-- x=+6 : top wall  [M: 0.50m wide × 0.30m deep] -->
    <model name="landmark_top_pos6">
      <static>1</static>
      <pose>6 1.1500 0.5 0 0 0</pose>
      <link name="link">
        <collision name="collision">
          <geometry><box><size>0.50 0.30 1.0</size></box></geometry>
        </collision>
        <visual name="visual">
          <geometry><box><size>0.50 0.30 1.0</size></box></geometry>
          <material>
            <ambient>0.3 0.3 0.5 1</ambient>
            <diffuse>0.4 0.4 0.6 1</diffuse>
            <specular>0.1 0.1 0.1 1</specular>
          </material>
        </visual>
      </link>
    </model>

    <!-- x=+8 : bottom wall  [D: 0.35m wide × 0.40m deep] -->
    <model name="landmark_bot_pos8">
      <static>1</static>
      <pose>8 -1.1000 0.5 0 0 0</pose>
      <link name="link">
        <collision name="collision">
          <geometry><box><size>0.35 0.40 1.0</size></box></geometry>
        </collision>
        <visual name="visual">
          <geometry><box><size>0.35 0.40 1.0</size></box></geometry>
          <material>
            <ambient>0.3 0.3 0.5 1</ambient>
            <diffuse>0.4 0.4 0.6 1</diffuse>
            <specular>0.1 0.1 0.1 1</specular>
          </material>
        </visual>
      </link>
    </model>

    <!-- x=+10 : top wall  [L: 0.90m wide × 0.35m deep] -->
    <model name="landmark_top_pos10">
      <static>1</static>
      <pose>10 1.1250 0.5 0 0 0</pose>
      <link name="link">
        <collision name="collision">
          <geometry><box><size>0.90 0.35 1.0</size></box></geometry>
        </collision>
        <visual name="visual">
          <geometry><box><size>0.90 0.35 1.0</size></box></geometry>
          <material>
            <ambient>0.3 0.3 0.5 1</ambient>
            <diffuse>0.4 0.4 0.6 1</diffuse>
            <specular>0.1 0.1 0.1 1</specular>
          </material>
        </visual>
      </link>
    </model>

    <!-- x=+12 : bottom wall  [S: 0.25m wide × 0.15m deep] -->
    <model name="landmark_bot_pos12">
      <static>1</static>
      <pose>12 -1.2250 0.5 0 0 0</pose>
      <link name="link">
        <collision name="collision">
          <geometry><box><size>0.25 0.15 1.0</size></box></geometry>
        </collision>
        <visual name="visual">
          <geometry><box><size>0.25 0.15 1.0</size></box></geometry>
          <material>
            <ambient>0.3 0.3 0.5 1</ambient>
            <diffuse>0.4 0.4 0.6 1</diffuse>
            <specular>0.1 0.1 0.1 1</specular>
          </material>
        </visual>
      </link>
    </model>

    <!-- x=+14 : top wall  [W: 1.20m wide × 0.20m deep] -->
    <model name="landmark_top_pos14">
      <static>1</static>
      <pose>14 1.2000 0.5 0 0 0</pose>
      <link name="link">
        <collision name="collision">
          <geometry><box><size>1.20 0.20 1.0</size></box></geometry>
        </collision>
        <visual name="visual">
          <geometry><box><size>1.20 0.20 1.0</size></box></geometry>
          <material>
            <ambient>0.3 0.3 0.5 1</ambient>
            <diffuse>0.4 0.4 0.6 1</diffuse>
            <specular>0.1 0.1 0.1 1</specular>
          </material>
        </visual>
      </link>
    </model>

    <!-- x=+16 : bottom wall  [M: 0.50m wide × 0.30m deep] -->
    <model name="landmark_bot_pos16">
      <static>1</static>
      <pose>16 -1.1500 0.5 0 0 0</pose>
      <link name="link">
        <collision name="collision">
          <geometry><box><size>0.50 0.30 1.0</size></box></geometry>
        </collision>
        <visual name="visual">
          <geometry><box><size>0.50 0.30 1.0</size></box></geometry>
          <material>
            <ambient>0.3 0.3 0.5 1</ambient>
            <diffuse>0.4 0.4 0.6 1</diffuse>
            <specular>0.1 0.1 0.1 1</specular>
          </material>
        </visual>
      </link>
    </model>

    <!-- x=+18 : top wall  [D: 0.35m wide × 0.40m deep] -->
    <model name="landmark_top_pos18">
      <static>1</static>
      <pose>18 1.1000 0.5 0 0 0</pose>
      <link name="link">
        <collision name="collision">
          <geometry><box><size>0.35 0.40 1.0</size></box></geometry>
        </collision>
        <visual name="visual">
          <geometry><box><size>0.35 0.40 1.0</size></box></geometry>
          <material>
            <ambient>0.3 0.3 0.5 1</ambient>
            <diffuse>0.4 0.4 0.6 1</diffuse>
            <specular>0.1 0.1 0.1 1</specular>
          </material>
        </visual>
      </link>
    </model>

  </world>
</sdf>
